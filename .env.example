# Copy to .env.local for `vercel dev` (never commit .env.local)
# On Vercel: Dashboard → Project → Settings → Environment Variables

ANTHROPIC_API_KEY=paste_your_key_from_anthropic_console

# After scoring, POSTs session summary to n8n (Slack/Sheets). Production webhook URL.
N8N_COACH_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/quadgrowth-coach
