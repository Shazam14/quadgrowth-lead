# Copy to .env.local for `vercel dev` (never commit .env.local)
# Vercel → Settings → Environment Variables

MISTRAL_API_KEY=paste_your_key_from_console_mistral_ai
# Optional — default is mistral-small-latest (use mistral-large-latest for stronger replies)
# MISTRAL_MODEL=mistral-small-latest

N8N_COACH_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/quadgrowth-coach
